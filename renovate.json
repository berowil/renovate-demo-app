{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "branchConcurrentLimit": 20,
  "prConcurrentLimit": 20,
  "prHourlyLimit" : 30,
  "extends": ["config:recommended","github>berowil/renovate-config"],
  "automergeType": "pr",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^tool-versions\\.txt$"],
      "matchStrings": ["node=(?<currentValue>[\\d\\.]+)\\n"],
      "depNameTemplate": "nodejs/node",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^deployment\\/deployment\\.ya?ml$/"
      ],
      "matchStrings": ["image:\\s+(?<depName>[a-z0-9\\-]+):(?<currentValue>[\\d\\.]+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major dependencies",
      "groupSlug": "major",
      "automerge": false,
      "enabled": true,
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "automerge": true,
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
