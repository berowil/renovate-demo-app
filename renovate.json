{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackagePatterns": ["^@types/"],
      "automerge": false
    },
    {
      "matchPackagePatterns": ["^@angular/"],
      "automerge": false
    },
    {
      "matchPackagePatterns": ["eslint"],
      "automerge": false
    }
  ]
}
